<div class="block">
  <div class="fr-container">
    <div class="fr-grid-row">
      <div class="fr-col-12">
        <div class="fr-pt-3w fr-pt-md-7w fr-pb-3w fr-pb-md-7w">
          <h1>{{ title }}</h1>
          {{ text|raw }}
          <div id="newsletter-messages" class="audiodesc-newsletter-messages fr-mb-3w" tabindex="-1">
            {% for type, messages in message_list %}
              {% if type == 'error' %}
                {% set error_summary %}
                  <p>{{ messages|length }} erreur{% if messages|length > 1 %}s ont été trouvées{% else %} a été trouvée{% endif %}</p>
                  <ul>{% for message in messages %}<li>{{ message }}</li>{% endfor %}</ul>
                {% endset %}
                {{ include('ui_suite_dsfr:alert', {message: error_summary, dismissible: false, variant: 'error__sm'}, with_context: false) }}
              {% else %}
                {% set variant = type == 'status' ? 'success__sm' : 'warning__sm' %}
                {% for message in messages %}
                  {{ include('ui_suite_dsfr:alert', {message: message, dismissible: false, variant: variant}, with_context: false) }}
                {% endfor %}
              {% endif %}
            {% endfor %}
          </div>
          {{ form }}
        </div>
      </div>
    </div>
  </div>
</div>
